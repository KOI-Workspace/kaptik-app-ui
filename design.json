{
  "meta": {
    "name": "Kaptik Weverse-inspired UI Design System",
    "version": "1.0.0",
    "generatedFor": "HTML/CSS/JavaScript implementation",
    "principle": "Dark, mobile-first, fandom media app UI inspired by the provided reference screens, with Kaptik brand accent changed to purple #8353EB.",
